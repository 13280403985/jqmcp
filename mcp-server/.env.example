# 复制为 .env 或写入托管平台环境变量（勿提交真实密钥）

# 监听（Railway / Render 等会注入 PORT）
HOST=0.0.0.0
PORT=8000
# http | sse | stdio
MCP_TRANSPORT=http

# Node 后端：项目根目录（默认自动设为上级目录，一般不必改）
# MERITCO_CONFIG_DIR=C:/path/to/JQMCP

# Playwright 查询超时（秒）
# MERITCO_QUERY_TIMEOUT_SEC=600

# 久谦凭证与 Playwright（与 meritco.local.env 相同，可在项目根 meritco.local.env 配置）
# MERITCO_USE_PERSIST_PROFILE=1
# MERITCO_PLAYWRIGHT_HEADLESS=1

# 可选：指定 node 可执行文件路径
# NODE_BIN=node
